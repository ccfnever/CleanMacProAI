{
  "productName": "CleanMacProAI",
  "version": "0.1.0",
  "identifier": "com.cleanmacproai.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'"
    },
    "windows": [
      {
        "label": "main",
        "title": "CleanMacProAI",
        "width": 1024,
        "height": 720,
        "resizable": true,
        "center": true,
        "decorations": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [],
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "13.0"
    }
  }
}
